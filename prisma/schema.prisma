generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  telegramUserId        String    @unique
  telegramChatId        String?
  timezone              String    @default("UTC")
  dailyAgendaEnabled    Boolean   @default(false)
  dailyAgendaHour       Int       @default(8)
  lastDailyAgendaSentAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  oauthAccounts      OAuthAccount[]
  messages           Message[]
  assistantRuns      AssistantRun[]
  toolCalls          ToolCall[]
  preferences        UserPreference[]
  salahSetting       SalahNotificationSetting?
  salahCityChoices   SalahCityChoice[]
  eventDrafts        CalendarEventDraft[]
  cancellationDrafts CalendarEventCancellationDraft[]
  updateDrafts       CalendarEventUpdateDraft[]
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model SalahNotificationSetting {
  id             String   @id @default(cuid())
  userId         String   @unique
  enabled        Boolean  @default(true)
  cityId         Int
  cityTitle      String
  region         String?
  district       String?
  latitude       String
  longitude      String
  timezoneOffset Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries SalahNotificationDelivery[]

  @@index([enabled])
}

model SalahNotificationDelivery {
  id         String   @id @default(cuid())
  settingId  String
  localDate  String
  prayerName String
  kind       String
  sentAt     DateTime @default(now())

  setting SalahNotificationSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique([settingId, localDate, prayerName, kind])
  @@index([settingId, sentAt])
}

model SalahCityChoice {
  id             String   @id @default(cuid())
  userId         String
  cityId         Int
  cityTitle      String
  region         String?
  district       String?
  latitude       String
  longitude      String
  timezoneOffset Int
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model OAuthAccount {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  accessToken  String?
  refreshToken String?
  expiryDate   DateTime?
  scopes       String?
  tokenType    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Message {
  id             String   @id @default(cuid())
  userId         String
  telegramChatId String
  role           String
  content        String
  raw            Json?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AssistantRun {
  id        String   @id @default(cuid())
  userId    String
  status    String
  input     String?
  output    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCalls ToolCall[]
}

model ToolCall {
  id             String   @id @default(cuid())
  userId         String
  assistantRunId String?
  name           String
  arguments      Json
  result         Json?
  error          String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assistantRun AssistantRun? @relation(fields: [assistantRunId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model CalendarEventDraft {
  id             String    @id @default(cuid())
  userId         String
  status         String
  title          String
  startTime      DateTime
  endTime        DateTime
  timezone       String
  description    String?
  location       String?
  recurrenceRule String?
  googleEventId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  confirmedAt    DateTime?
  canceledAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model CalendarEventCancellationDraft {
  id            String    @id @default(cuid())
  userId        String
  status        String
  googleEventId String
  title         String
  startTime     DateTime?
  endTime       DateTime?
  timezone      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  confirmedAt   DateTime?
  canceledAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model CalendarEventUpdateDraft {
  id                String    @id @default(cuid())
  userId            String
  status            String
  googleEventId     String
  currentTitle      String
  newTitle          String?
  newStartTime      DateTime?
  newEndTime        DateTime?
  timezone          String
  newDescription    String?
  newLocation       String?
  newRecurrenceRule String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  confirmedAt       DateTime?
  canceledAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}
